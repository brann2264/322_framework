%ASDASDSAD17 <- %ASDASDSAD13 + %ASDASDSAD11
%ASDASDSAD18 <- %ASDASDSAD17 + %fib_arr
store %ASDASDSAD18 <- 1

call print (3)
call print (3)

%i <- 2
:loop_start
%loop_done <- %i >= 21
br %loop_done :loop_end
%i_sub_2 <- %i - 2
%ASDASDSAD19 <- 16
%ASDASDSAD20 <- 1
%ASDASDSAD21 <- 0
%ASDASDSAD22 <- %ASDASDSAD20 * %i_sub_2
%ASDASDSAD21 <- %ASDASDSAD21 + %ASDASDSAD22
