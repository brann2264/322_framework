%ASDASDSAD24 <- %ASDASDSAD24 >> 1
%ASDASDSAD20 <- %ASDASDSAD20 * %ASDASDSAD24
%ASDASDSAD25 <- %ASDASDSAD21 + %ASDASDSAD19
%ASDASDSAD26 <- %ASDASDSAD25 + %fib_arr
