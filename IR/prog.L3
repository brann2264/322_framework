%ASDASDSAD28 <- %ASDASDSAD28 * %ASDASDSAD32
%ASDASDSAD33 <- %ASDASDSAD29 + %ASDASDSAD27
%ASDASDSAD34 <- %ASDASDSAD33 + %fib_arr
